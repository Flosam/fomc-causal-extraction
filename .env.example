# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# Google AI (Gemini) — get a free key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# GitHub personal access token — used for GitHub Models free inference
# Generate at github.com/settings/tokens (needs read access)
GITHUB_TOKEN=your_github_token_here

# Kaggle credentials (for automated dataset download)
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here
